ANTHROPIC_API_KEY=sk-ant-coloque-sua-chave-aqui
PORT=3333

# Criptografia de senhas no banco (AES-256-GCM)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=cole-aqui-64-chars-hex

# Playwright: false = browser visível (debug), true = headless (produção)
PLAYWRIGHT_HEADLESS=true

# Mock mode: true = dados fictícios, false = scraping real
MOCK_MODE=true
